# 影片 Provider 選擇：mock | fal
# mock = 不呼叫真的 API，產生假影片把流程跑通（不用 key）
# fal  = 透過 fal.ai 聚合層呼叫真的影片模型（需要 FAL_KEY）
VIDEO_PROVIDER=mock

# fal.ai 的 API key（到 https://fal.ai 申請）
# 只有 VIDEO_PROVIDER=fal 時才需要
FAL_KEY=

# fal.ai 上要用的模型 endpoint
# 例：fal-ai/kling-video/v2/standard/text-to-video
#     fal-ai/sora-2/text-to-video
FAL_TEXT_MODEL=fal-ai/kling-video/v2/standard/text-to-video
FAL_IMAGE_MODEL=fal-ai/kling-video/v2/standard/image-to-video

# 允許跨域的前端網址
CORS_ORIGINS=http://localhost:5173
